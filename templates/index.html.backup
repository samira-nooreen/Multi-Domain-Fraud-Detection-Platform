<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>MDFDP</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    <script src="{{ url_for('static', filename='script.js') }}"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/chatbot.css') }}">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.7.1/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.7.1/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>
    <nav class="navbar">
        <div class="navbar-logo">
            <div class="shield-icon">
                <svg viewBox="0 0 24 24">
                    <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z" />
                </svg>
            </div>
            <div class="navbar-logo-text">
                Multi-Domain Fraud Detection <br>
                <span style="font-weight: 700;">Platform (MDFDP)</span>
            </div>
        </div>

        <ul class="navbar-links">
            <li><a href="#">Home</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="/analytics">Analytics</a></li>
            <li><a href="/security">Security</a></li>
            <li><a href="#report-fraud">Report</a></li>
            <li><a href="#">Contact</a></li>
            <li><a href="/logout">Logout</a></li>
        </ul>

        <a href="/profile" class="navbar-btn" style="text-decoration: none;">Profile</a>
    </nav>

    <main>
        {% if suspicious_login %}
        <div
            style="background: rgba(255, 111, 0, 0.15); border: 1px solid #ff6f00; color: #ff6f00; padding: 15px 20px; margin: 20px 40px; border-radius: 8px; display: flex; align-items: center; gap: 15px; animation: slideDown 0.5s ease-out;">
            <i class="fas fa-exclamation-triangle" style="font-size: 1.2rem;"></i>
            <div>
                <strong style="display: block; margin-bottom: 4px;">Suspicious Login Detected</strong>
                <span style="font-size: 0.9rem; opacity: 0.9;">We noticed unusual activity during your recent login.
                    Please
                    review your account security settings.</span>
            </div>
            <button onclick="this.parentElement.style.display='none'"
                style="background: none; border: none; color: #ff6f00; margin-left: auto; cursor: pointer; font-size: 1.2rem;">&times;</button>
        </div>
        {% endif %}
        <section class="hero">
            <div class="hero-left">
                <h1>Detecting Fraud,<br />Securing Transactions</h1>
                <p>
                    Empowering businesses with cutting-edge AI to detect and prevent
                    fraud across multiple domains. Safeguard your assets and build trust
                    with our innovative solutions. Join us!
                </p>
                <button class="know-btn" onclick="knowMore()">Know more</button>
            </div>

            <div class="hero-right">
                <video class="hero-video" autoplay loop muted playsinline>
                    <source src="/static/video/background.mp4" type="video/mp4">
                    Your browser does not support the video tag.
                </video>
            </div>
        </section>
    </main>

    <!-- Domain cards section -->
    <section class="domain-cards">
        <div class="card">
            <div class="card-icon"><i class="fa-solid fa-cloud-arrow-up"></i></div>
            <div class="card-title">UPI</div>
            <div class="card-desc">Real-time UPI fraud pattern identification.</div>
            <button class="detect-btn" onclick="window.location.href='/detect_upi'">Detect</button>
        </div>

        <div class="card">
            <div class="card-icon"><i class="fa-solid fa-credit-card"></i></div>
            <div class="card-title">Credit</div>
            <div class="card-desc">Classify transactions accurately.</div>
            <button class="detect-btn" onclick="window.location.href='/detect_credit'">Detect</button>
        </div>
        <div class="card">
            <div class="card-icon"><i class="fa-solid fa-money-check-dollar"></i></div>
            <div class="card-title">Loan</div>
            <div class="card-desc">Predict loan defaults effectively.</div>
            <button class="detect-btn" onclick="window.location.href='/detect_loan'">Detect</button>
        </div>
        <div class="card">
            <div class="card-icon"><i class="fa-solid fa-shield"></i></div>
            <div class="card-title">Insurance</div>
            <div class="card-desc">Detect fraudulent claims efficiently.</div>
            <button class="detect-btn" onclick="window.location.href='/detect_insurance'">Detect</button>
        </div>
        <div class="card">
            <div class="card-icon"><i class="fa-solid fa-bullseye"></i></div>
            <div class="card-title">Click</div>
            <div class="card-desc">Analyze ad clicks effectively.</div>
            <button class="detect-btn" onclick="window.location.href='/detect_click'">Detect</button>
        </div>
        <div class="card">
            <div class="card-icon"><i class="fa-solid fa-newspaper"></i></div>
            <div class="card-title">Fake</div>
            <div class="card-desc">Classify news accurately.</div>
            <button class="detect-btn" onclick="window.location.href='/detect_fake_news'">Detect</button>
        </div>
        <div class="card">
            <div class="card-icon"><i class="fa-solid fa-envelope-open-text"></i></div>
            <div class="card-title">Spam</div>
            <div class="card-desc">Flag phishing emails efficiently.</div>
            <button class="detect-btn" onclick="window.location.href='/detect_spam'">Detect</button>
        </div>
        <div class="card">
            <div class="card-icon"><i class="fa-solid fa-link"></i></div>
            <div class="card-title">Phishing</div>
            <div class="card-desc">Detect phishing sites accurately.</div>
            <button class="detect-btn" onclick="window.location.href='/detect_phishing'">Detect</button>
        </div>
        <div class="card">
            <div class="card-icon"><i class="fa-solid fa-robot"></i></div>
            <div class="card-title">Fake Profile/Bot</div>
            <div class="card-desc">Detect bots or fake profiles using network and behavior analysis.</div>
            <button class="detect-btn" onclick="window.location.href='/detect_bot'">Detect</button>
        </div>
        <div class="card">
            <div class="card-icon"><i class="fa-solid fa-id-badge"></i></div>
            <div class="card-title">Document Forgery</div>
            <div class="card-desc">Detect tampered identity cards with OCR and image analysis.</div>
            <button class="detect-btn" onclick="window.location.href='/detect_forgery'">Detect</button>
        </div>
    </section>

    <!-- Real-Time Dashboard Section -->
    <section class="realtime-dashboard">
        <div class="dashboard-grid">
            <!-- Interactive Heatmap -->
            <div class="dashboard-card heatmap">
                <div class="dashboard-title">Real-Time Fraud Heatmap</div>
                <div id="india-map"></div>
                <div class="dashboard-card top-cities">
                    <div class="dashboard-title">Top Fraud Cities</div>
                    <ul class="top-cities-list">
                        <li><span class="dot critical"></span> Mumbai - Critical</li>
                        <li><span class="dot high"></span> Delhi - High</li>
                        <li><span class="dot medium"></span> Bangalore - Medium</li>
                        <li><span class="dot medium"></span> Kolkata - Medium</li>
                        <li><span class="dot low"></span> Chennai - Low</li>
                        <li><span class="dot high"></span> Hyderabad - High</li>
                        <li><span class="dot medium"></span> Pune - Medium</li>
                        <li><span class="dot medium"></span> Ahmedabad - Medium</li>
                        <li><span class="dot low"></span> Jaipur - Low</li>
                        <li><span class="dot high"></span> Lucknow - High</li>
                    </ul>
                </div>
            </div>

            <!-- Incident Distribution -->
            <div class="dashboard-card incident">
                <div class="dashboard-title">Incident Distribution</div>
                <ul class="incident-list">
                    <li><span class="dot dot-orange"></span>Bangalore <span class="right">234</span> <span
                            class="chip high">high</span></li>
                    <li><span class="dot dot-yellow"></span>Chennai <span class="right">187</span> <span
                            class="chip medium">medium</span></li>
                    <li><span class="dot dot-yellow"></span>Kolkata <span class="right">156</span> <span
                            class="chip medium">medium</span></li>
                    <li><span class="dot dot-yellow"></span>Delhi <span class="right">198</span> <span
                            class="chip medium">medium</span></li>
                </ul>
            </div>

            <!-- Fraud Type Distribution -->
            <div class="dashboard-card distribution">
                <div class="dashboard-title">Fraud Type Distribution</div>
                <div class="distribution-tabs">
                    <button class="tab" onclick="updateFraudStats('1h')">1h</button>
                    <button class="tab" onclick="updateFraudStats('6h')">6h</button>
                    <button class="tab active" onclick="updateFraudStats('24h')">24h</button>
                    <button class="tab" onclick="updateFraudStats('7d')">7d</button>
                    <button class="tab" onclick="updateFraudStats('30d')">30d</button>
                </div>
                <div class="distribution-bar" id="fraud-stats">
                    <div><span class="bar pink" style="width:34%"></span>UPI Fraud <span class="value">456 cases
                            34%</span></div>
                    <div><span class="bar orange" style="width:28%"></span>Credit Card <span class="value">378 cases
                            28%</span>
                    </div>
                    <div><span class="bar purple" style="width:18%"></span>Identity Theft <span class="value">243 cases
                            18%</span>
                    </div>
                    <div><span class="bar blue" style="width:12%"></span>Phishing <span class="value">162 cases
                            12%</span></div>
                    <div><span class="bar gray" style="width:8%"></span>Other <span class="value">108 cases 8%</span>
                    </div>
                </div>
            </div>

            <script>
                // Fraud statistics data for different time periods
                const fraudData = {
                    '1h': {
                        'UPI Fraud': { cases: 23, percent: 38 },
                        'Credit Card': { cases: 18, percent: 30 },
                        'Identity Theft': { cases: 10, percent: 17 },
                        'Phishing': { cases: 6, percent: 10 },
                        'Other': { cases: 3, percent: 5 }
                    },
                    '6h': {
                        'UPI Fraud': { cases: 142, percent: 36 },
                        'Credit Card': { cases: 108, percent: 27 },
                        'Identity Theft': { cases: 75, percent: 19 },
                        'Phishing': { cases: 48, percent: 12 },
                        'Other': { cases: 24, percent: 6 }
                    },
                    '24h': {
                        'UPI Fraud': { cases: 456, percent: 34 },
                        'Credit Card': { cases: 378, percent: 28 },
                        'Identity Theft': { cases: 243, percent: 18 },
                        'Phishing': { cases: 162, percent: 12 },
                        'Other': { cases: 108, percent: 8 }
                    },
                    '7d': {
                        'UPI Fraud': { cases: 2845, percent: 32 },
                        'Credit Card': { cases: 2456, percent: 28 },
                        'Identity Theft': { cases: 1678, percent: 19 },
                        'Phishing': { cases: 1234, percent: 14 },
                        'Other': { cases: 678, percent: 7 }
                    },
                    '30d': {
                        'UPI Fraud': { cases: 12456, percent: 33 },
                        'Credit Card': { cases: 10567, percent: 28 },
                        'Identity Theft': { cases: 7890, percent: 21 },
                        'Phishing': { cases: 4567, percent: 12 },
                        'Other': { cases: 2345, percent: 6 }
                    }
                };

                function updateFraudStats(period) {
                    // Update active tab
                    document.querySelectorAll('.distribution-tabs .tab').forEach(tab => {
                        tab.classList.remove('active');
                        if (tab.innerText.toLowerCase() === period) {
                            tab.classList.add('active');
                        }
                    });

                    // Update stats
                    const data = fraudData[period];
                    const container = document.getElementById('fraud-stats');
                    container.innerHTML = '';

                    const colors = ['pink', 'orange', 'purple', 'blue', 'gray'];
                    let i = 0;

                    for (const [type, stats] of Object.entries(data)) {
                        const div = document.createElement('div');
                        div.innerHTML = `<span class="bar ${colors[i]}" style="width:${stats.percent}%"></span>${type} <span class="value">${stats.cases} cases ${stats.percent}%</span>`;
                        container.appendChild(div);
                        i++;
                    }
                }
            </script>
        </div>
    </section>

    <!-- Report Fraud Section -->
    <section id="report-fraud" style="padding: 40px 20px; background: #0d0d0f; margin-top: 40px;">
        <div style="max-width: 800px; margin: 0 auto; text-align: center;">
            <h2
                style="font-size: 2.5rem; margin-bottom: 20px; background: linear-gradient(135deg, #8876f8 0%, #c9baff 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">
                Report Suspicious Activity</h2>
            <p style="color: #b7b3c9; margin-bottom: 30px; font-size: 1.1rem;">
                Help us make the digital world safer. If you've encountered a potential fraud attempt, report it here.
                Our AI will analyze it instantly.
            </p>

            <div
                style="background: #14141b; padding: 30px; border-radius: 16px; border: 1px solid rgba(136, 118, 248, 0.2); text-align: left;">
                <h3 style="color: #8876f8; margin-bottom: 15px; font-size: 1.3rem;">What You Can Report:</h3>
                <ul style="color: #e6e6e6; margin-bottom: 25px; list-style-position: inside; line-height: 1.6;">
                    <li>Suspicious UPI IDs or payment requests</li>
                    <li>Phishing URLs or fake websites</li>
                    <li>Fraudulent phone numbers or SMS</li>
                    <li>Fake social media profiles</li>
                </ul>

                <form id="report-form" onsubmit="handleReport(event)">
                    <div style="margin-bottom: 15px;">
                        <label style="color: #8876f8; display: block; margin-bottom: 8px; font-weight: 600;">Title or
                            Subject</label>
                        <input type="text" placeholder="e.g., Fake UPI Request from..."
                            style="width: 100%; padding: 12px; background: #0d0d0f; border: 1px solid #2a2a35; color: white; border-radius: 8px;">
                    </div>

                    <div style="margin-bottom: 15px;">
                        <label style="color: #8876f8; display: block; margin-bottom: 8px; font-weight: 600;">Description
                            *</label>
                        <textarea placeholder="Describe what happened..." required
                            style="width: 100%; padding: 12px; background: #0d0d0f; border: 1px solid #2a2a35; color: white; border-radius: 8px; min-height: 100px;"></textarea>
                    </div>

                    <div style="margin-bottom: 15px;">
                        <label style="color: #8876f8; display: block; margin-bottom: 8px; font-weight: 600;">Source
                            (URL, Phone, ID)</label>
                        <input type="text" placeholder="e.g., 9876543210 or example.com"
                            style="width: 100%; padding: 12px; background: #0d0d0f; border: 1px solid #2a2a35; color: white; border-radius: 8px;">
                    </div>

                    <div style="margin-bottom: 20px;">
                        <label
                            style="color: #8876f8; display: block; margin-bottom: 8px; font-weight: 600;">Category</label>
                        <select
                            style="width: 100%; padding: 12px; background: #0d0d0f; border: 1px solid #2a2a35; color: white; border-radius: 8px;">
                            <option>UPI Fraud</option>
                            <option>Phishing</option>
                            <option>Identity Theft</option>
                            <option>Other</option>
                        </select>
                    </div>

                    <div style="margin-bottom: 20px;">
                        <label style="color: #8876f8; display: block; margin-bottom: 8px; font-weight: 600;">Supporting
                            Evidence</label>
                        <input type="file" style="color: #b7b3c9;">
                    </div>

                    <button type="submit" class="report-btn"
                        style="background: linear-gradient(135deg, #8876f8 0%, #7059d2 100%); color: white; padding: 15px 30px; border: none; border-radius: 8px; font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: transform 0.2s; margin-top: 10px;">
                        Submit Report
                    </button>
                </form>

                <div id="report-success"
                    style="display: none; margin-top: 20px; padding: 15px; background: rgba(34, 209, 104, 0.1); border: 1px solid #22d168; border-radius: 8px; color: #22d168;">
                    <h4 style="color: #22d168; margin-bottom: 15px;">Analysis Result:</h4>
                    <p><strong>Risk Score:</strong> High (87/100)</p>
                    <p><strong>Action Taken:</strong> Flagged for manual review. Similar patterns detected in 12 other
                        reports.
                    </p>
                </div>
            </div>

            <div style="margin-top: 40px; text-align: left;">
                <h3 style="color: #8876f8; margin-bottom: 15px; font-size: 1.3rem;">What Happens Next:</h3>
                <div style="display: flex; gap: 20px; flex-wrap: wrap;">
                    <div
                        style="flex: 1; min-width: 200px; background: #14141b; padding: 20px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05);">
                        <div style="color: #8876f8; font-size: 1.5rem; margin-bottom: 10px;">1. AI Analysis</div>
                        <p style="color: #b7b3c9; font-size: 0.9rem;">Our ML models instantly analyze the report for
                            known fraud patterns.</p>
                    </div>
                    <div
                        style="flex: 1; min-width: 200px; background: #14141b; padding: 20px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05);">
                        <div style="color: #8876f8; font-size: 1.5rem; margin-bottom: 10px;">2. Verification</div>
                        <p style="color: #b7b3c9; font-size: 0.9rem;">High-risk reports are verified by our security
                            team.</p>
                    </div>
                    <div
                        style="flex: 1; min-width: 200px; background: #14141b; padding: 20px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05);">
                        <div style="color: #8876f8; font-size: 1.5rem; margin-bottom: 10px;">3. Action</div>
                        <p style="color: #b7b3c9; font-size: 0.9rem;">Valid threats are blocked and shared with
                            authorities.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script>
        function handleReport(e) {
            e.preventDefault();
            const btn = e.target.querySelector('button');
            const originalText = btn.innerText;

            btn.innerText = 'Analyzing...';
            btn.disabled = true;
            btn.style.opacity = '0.7';

            // Simulate AI analysis
            setTimeout(() => {
                btn.innerText = originalText;
                btn.disabled = false;
                btn.style.opacity = '1';

                document.getElementById('report-success').style.display = 'block';
                document.getElementById('report-form').reset();

                // Scroll to result
                document.getElementById('report-success').scrollIntoView({ behavior: 'smooth' });
            }, 2000);
        }
    </script>

    <!-- Chatbot Integration -->
    <div class="chatbot-container">
        <div class="chatbot-toggle" onclick="toggleChatbot()">
            <i class="fas fa-robot"></i>
        </div>
        <div class="chatbot-window" id="chatbot-window">
            <div class="chatbot-header">
                <div class="chatbot-title">
                    <i class="fas fa-shield-alt"></i> Security Assistant
                </div>
                <button class="close-btn" onclick="toggleChatbot()">&times;</button>
            </div>
            <div class="chatbot-messages" id="chatbot-messages">
                <div class="message bot-message">
                    Hello! I'm your AI security assistant. How can I help you today?
                </div>
            </div>
            <div class="chatbot-input">
                <input type="text" id="user-input" placeholder="Type your message...">
                const mapContainer = document.getElementById('india-map');
                if (mapContainer) {
                const map = L.map('india-map').setView([20.5937, 78.9629], 5);
                L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors
                &copy; <a href="https://carto.com/attributions">CARTO</a>',
                subdomains: 'abcd',
                maxZoom: 19
                }).addTo(map);

                // Add some dummy hotspots
                const hotspots = [
                { city: "Mumbai", coords: [19.0760, 72.8777], level: "critical", cases: 456 },
                { city: "Delhi", coords: [28.6139, 77.2090], level: "high", cases: 378 },
                { city: "Bangalore", coords: [12.9716, 77.5946], level: "medium", cases: 234 },
                { city: "Hyderabad", coords: [17.3850, 78.4867], level: "high", cases: 312 }
                ];

                const colors = { critical: '#ff0000', high: '#ff6f00', medium: '#ffeb3b', low: '#4caf50' };

                hotspots.forEach(h => {
                L.circleMarker(h.coords, {
                radius: 8,
                fillColor: colors[h.level],
                color: "#fff",
                weight: 1,
                opacity: 1,
                fillOpacity: 0.8
                }).addTo(map).bindPopup(`<b>${h.city}</b><br>Risk: ${h.level.toUpperCase()}<br>Cases: ${h.cases}`);
                });
                }
                });
                </script>
</body>

</html>