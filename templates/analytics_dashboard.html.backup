<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analytics & Monitoring - MDFDP</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        * {
            margin-bottom: 2rem;
            border-bottom: 2px solid rgba(255, 255, 255, 0.1);
        }

        .tab-btn {
            background: transparent;
            border: none;
            color: #b7b3c9;
            padding: 1rem 2rem;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            position: relative;
            transition: all 0.3s;
        }

        .tab-btn.active {
            color: #8876f8;
        }

        .tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(135deg, #8876f8 0%, #c9baff 100%);
        }

        .tab-btn:hover {
            color: #8876f8;
        }

        /* Tab Content */
        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
            animation: fadeIn 0.5s;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Dashboard Grid */
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .dashboard-card {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .dashboard-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(255, 23, 68, 0.2);
        }

        .card-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #8876f8;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* Heatmap */
        #heatmap-container {
            height: 600px;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 1rem;
        }

        .heatmap-controls {
            display: flex;
            gap: 1rem;
            margin-bottom: 1rem;
            flex-wrap: wrap;
        }

        .control-btn {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: #e6e6e6;
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 600;
        }

        .control-btn.active {
            background: linear-gradient(135deg, #8876f8 0%, #7059d2 100%);
            border-color: #8876f8;
        }

        .control-btn:hover {
            background: rgba(255, 23, 68, 0.2);
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.05);
            padding: 1.5rem;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            text-align: center;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            color: #8876f8;
            margin-bottom: 0.5rem;
        }

        .stat-label {
            color: #b7b3c9;
            font-size: 0.9rem;
        }

        /* Anomaly List */
        .anomaly-list {
            list-style: none;
            max-height: 500px;
            overflow-y: auto;
        }

        .anomaly-item {
            background: rgba(255, 255, 255, 0.05);
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 0.75rem;
            border-left: 4px solid;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: transform 0.2s;
        }

        .anomaly-item:hover {
            transform: translateX(5px);
        }

        .anomaly-item.critical {
            border-color: #7059d2;
        }

        .anomaly-item.high {
            border-color: #ff6f00;
        }

        .anomaly-item.medium {
            border-color: #f9a825;
        }

        .anomaly-item.low {
            border-color: #2e7d32;
        }

        .anomaly-badge {
            padding: 0.25rem 0.75rem;
            border-radius: 12px;
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
        }

        .anomaly-badge.critical {
            background: rgba(213, 0, 0, 0.2);
            color: #ff5252;
        }

        .anomaly-badge.high {
            background: rgba(255, 111, 0, 0.2);
            color: #ff9800;
        }

        .anomaly-badge.medium {
            background: rgba(249, 168, 37, 0.2);
            color: #ffc107;
        }

        .anomaly-badge.low {
            background: rgba(46, 125, 50, 0.2);
            color: #66bb6a;
        }

        /* Loss Estimation Form */
        .estimation-form {
            display: grid;
            gap: 1.5rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .form-group label {
            color: #8876f8;
            font-weight: 600;
        }

        .form-group input,
        .form-group select {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: #e6e6e6;
            padding: 0.75rem;
            border-radius: 8px;
            font-size: 1rem;
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: #8876f8;
        }

        .estimate-btn {
            background: linear-gradient(135deg, #8876f8 0%, #7059d2 100%);
            color: white;
            padding: 1rem 2rem;
            border: none;
            border-radius: 8px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .estimate-btn:hover {
            transform: translateY(-2px);
        }

        /* Results */
        .results-container {
            margin-top: 2rem;
            padding: 2rem;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            display: none;
        }

        .results-container.show {
            display: block;
            animation: fadeIn 0.5s;
        }

        .result-item {
            display: flex;
            justify-content: space-between;
            padding: 1rem 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .result-item:last-child {
            border-bottom: none;
        }

        .result-label {
            color: #b7b3c9;
            font-weight: 600;
        }

        .result-value {
            color: #8876f8;
            font-weight: 700;
            font-size: 1.2rem;
        }

        /* Chart Container */
        .chart-container {
            height: 400px;
            margin-top: 1rem;
        }

        /* Scrollbar Styling */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(255, 23, 68, 0.5);
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 23, 68, 0.7);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
            }

            .page-header h1 {
                font-size: 2rem;
            }

            .tab-navigation {
                overflow-x: auto;
            }
        }
    </style>
</head>

<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="navbar-logo">
            <h1><i class="fas fa-chart-line"></i> Analytics & Monitoring</h1>
        </div>
        <a href="/" class="back-btn">
            <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
    </nav>

    <!-- Main Container -->
    <div class="container">
        <!-- Page Header -->
        <div class="page-header">
            <h1>📊 Analytics & Monitoring Extensions</h1>
            <p>Comprehensive fraud analytics, real-time monitoring, and financial impact estimation</p>
        </div>

        <!-- Tab Navigation -->
        <div class="tab-navigation">
            <button class="tab-btn active" onclick="switchTab('heatmaps')">
                <i class="fas fa-map-marked-alt"></i> Fraud Heatmaps
            </button>
            <button class="tab-btn" onclick="switchTab('anomalies')">
                <i class="fas fa-exclamation-triangle"></i> Anomaly Detection
            </button>
            <button class="tab-btn" onclick="switchTab('estimation')">
                <i class="fas fa-calculator"></i> Loss Estimation
            </button>
        </div>

        <!-- Tab 1: Fraud Heatmaps -->
        <div id="tab-heatmaps" class="tab-content active">
            <div class="dashboard-card">
                <div class="card-title">
                    <i class="fas fa-globe"></i> Interactive Fraud Heatmap
                </div>

                <!-- Heatmap Controls -->
                <div class="heatmap-controls">
                    <button class="control-btn active" onclick="filterHeatmap('all')">All Fraud Types</button>
                    <button class="control-btn" onclick="filterHeatmap('upi')">UPI Fraud</button>
                    <button class="control-btn" onclick="filterHeatmap('credit')">Credit Card</button>
                    <button class="control-btn" onclick="filterHeatmap('phishing')">Phishing</button>
                    <button class="control-btn" onclick="filterHeatmap('identity')">Identity Theft</button>
                </div>

                <!-- Map Container -->
                <div id="heatmap-container"></div>

                <!-- Statistics -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-value" id="total-cases">2,847</div>
                        <div class="stat-label">Total Cases (24h)</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="critical-zones">12</div>
                        <div class="stat-label">Critical Zones</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="avg-severity">67%</div>
                        <div class="stat-label">Avg Severity</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="trend">+23%</div>
                        <div class="stat-label">24h Trend</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 2: Anomaly Detection -->
        <div id="tab-anomalies" class="tab-content">
            <div class="dashboard-grid">
                <!-- Real-time Anomalies -->
                <div class="dashboard-card">
                    <div class="card-title">
                        <i class="fas fa-bell"></i> Real-Time Anomalies
                    </div>
                    <ul class="anomaly-list" id="anomaly-list">
                        <!-- Populated by JavaScript -->
                    </ul>
                </div>

                <!-- Anomaly Statistics -->
                <div class="dashboard-card">
                    <div class="card-title">
                        <i class="fas fa-chart-bar"></i> Anomaly Statistics
                    </div>
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-value" id="anomaly-count">156</div>
                            <div class="stat-label">Active Anomalies</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-value" id="critical-anomalies">23</div>
                            <div class="stat-label">Critical</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-value" id="resolved-anomalies">89</div>
                            <div class="stat-label">Resolved (24h)</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-value" id="avg-response">4.2m</div>
                            <div class="stat-label">Avg Response Time</div>
                        </div>
                    </div>

                    <!-- Anomaly Chart -->
                    <div class="chart-container">
                        <canvas id="anomaly-chart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 3: Loss Estimation -->
        <div id="tab-estimation" class="tab-content">
            <div class="dashboard-grid">
                <!-- Estimation Form -->
                <div class="dashboard-card">
                    <div class="card-title">
                        <i class="fas fa-calculator"></i> Attack Scenario Configuration
                    </div>
                    <form class="estimation-form" id="estimation-form">
                        <div class="form-group">
                            <label for="attack-type">Attack Type</label>
                            <select id="attack-type" required>
                                <option value="">Select attack type...</option>
                                <option value="upi">UPI Fraud</option>
                                <option value="credit">Credit Card Fraud</option>
                                <option value="phishing">Phishing Campaign</option>
                                <option value="identity">Identity Theft</option>
                                <option value="ransomware">Ransomware</option>
                                <option value="ddos">DDoS Attack</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="attack-scale">Attack Scale</label>
                            <select id="attack-scale" required>
                                <option value="">Select scale...</option>
                                <option value="small">Small (1-100 targets)</option>
                                <option value="medium">Medium (100-1,000 targets)</option>
                                <option value="large">Large (1,000-10,000 targets)</option>
                                <option value="massive">Massive (10,000+ targets)</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="avg-transaction">Average Transaction Value (₹)</label>
                            <input type="number" id="avg-transaction" placeholder="e.g., 5000" required>
                        </div>

                        <div class="form-group">
                            <label for="success-rate">Estimated Success Rate (%)</label>
                            <input type="number" id="success-rate" min="0" max="100" placeholder="e.g., 15" required>
                        </div>

                        <div class="form-group">
                            <label for="duration">Attack Duration (hours)</label>
                            <input type="number" id="duration" min="1" placeholder="e.g., 24" required>
                        </div>

                        <div class="form-group">
                            <label for="detection-delay">Detection Delay (minutes)</label>
                            <input type="number" id="detection-delay" min="0" placeholder="e.g., 30" required>
                        </div>

                        <button type="submit" class="estimate-btn">
                            <i class="fas fa-chart-line"></i> Calculate Loss Estimation
                        </button>
                    </form>
                </div>

                <!-- Results -->
                <div class="dashboard-card">
                    <div class="card-title">
                        <i class="fas fa-file-invoice-dollar"></i> Financial Impact Analysis
                    </div>
                    <div id="estimation-results" class="results-container">
                        <div class="result-item">
                            <span class="result-label">Estimated Direct Loss:</span>
                            <span class="result-value" id="direct-loss">₹0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Indirect Costs (Recovery, Legal):</span>
                            <span class="result-value" id="indirect-loss">₹0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Reputational Damage:</span>
                            <span class="result-value" id="reputation-loss">₹0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Total Estimated Loss:</span>
                            <span class="result-value" id="total-loss">₹0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Affected Users:</span>
                            <span class="result-value" id="affected-users">0</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Risk Level:</span>
                            <span class="result-value" id="risk-level">-</span>
                        </div>
                    </div>

                    <!-- Recommendations -->
                    <div id="recommendations" style="margin-top: 2rem; display: none;">
                        <div class="card-title">
                            <i class="fas fa-lightbulb"></i> Recommendations
                        </div>
                        <ul id="recommendation-list" style="color: #b7b3c9; line-height: 2;">
                            <!-- Populated by JavaScript -->
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="{{ url_for('static', filename='js/analytics.js') }}"></script>
</body>

</html>