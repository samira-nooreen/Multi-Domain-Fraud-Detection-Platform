}

/* Recommendation Box */
.recommendation {
  background: linear-gradient(135deg, #8876f8 0%, #7059d2 100%);
  color: white;
  padding: 25px;
  border-radius: 12px;
  text-align: center;
  font-size: 1.15rem;
  font-weight: 600;
  box-shadow: 0 4px 20px rgba(136, 118, 248, 0.3);
}

/* Loading Spinner */
.loading {
  display: none;
  text-align: center;
  padding: 50px;
}

.loading.show {
  display: block;
}

.spinner {
  border: 4px solid #29293a;
  border-top: 4px solid #8876f8;
  border-radius: 50%;
  width: 50px;
  height: 50px;
  animation: spin 1s linear infinite;
  margin: 0 auto 20px;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }

  100% {
    transform: rotate(360deg);
  }
}

/* Responsive Design */
@media (max-width: 768px) {
  .module-content {
    grid-template-columns: 1fr;
  }

  .form-row {
    grid-template-columns: 1fr;
  }

  .module-header h1 {
    font-size: 2rem;
  }

  border: none;
  border-radius: 10px;
  font-size: 1.1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-top: 15px;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(136, 118, 248, 0.4);
}

.btn-primary:active {
  transform: translateY(0);
}

/* Result Card */
.result-card {
  display: none;
}

.result-card.show {
  display: block;
  animation: slideIn 0.5s ease;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Result Header */
.result-header {
  text-align: center;
  padding: 35px;
  border-radius: 15px;
  margin-bottom: 25px;
}

.result-header.safe {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: white;
}

.result-header.fraud {
  background: linear-gradient(135deg, #eb3349 0%, #f45c43 100%);
  color: white;
}

.result-header.warning {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}

.result-header h3 {
  font-size: 2rem;
  margin-bottom: 10px;
  font-weight: 700;
}

.result-header .icon {
  font-size: 4rem;
  margin-bottom: 15px;
}

/* Result Details */
.result-details {
  background: #0d0d0f;
  padding: 25px;
  border-radius: 12px;
  margin-bottom: 20px;
  border: 1px solid #29293a;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 14px 0;
  border-bottom: 1px solid #29293a;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-weight: 600;
  color: #b7b3c9;
  font-size: 1.05rem;
}

.detail-value {
  color: #e6e6e6;
  font-weight: 500;
}

/* Risk Badges */
.risk-badge {
  display: inline-block;
  padding: 6px 16px;
  border-radius: 20px;
  font-weight: 600;
  font-size: 0.95rem;
}

.risk-low {
  background: #d4edda;
  color: #155724;
}

.risk-medium {
  background: #fff3cd;
  color: #856404;
}

.risk-high {
  background: #f8d7da;
  color: #721c24;
}

.risk-critical {
  background: #f5c6cb;
  color: #721c24;
}

/* Recommendation Box */
.recommendation {
  background: linear-gradient(135deg, #8876f8 0%, #7059d2 100%);
  color: white;
  padding: 25px;
  border-radius: 12px;
  text-align: center;
  font-size: 1.15rem;
  font-weight: 600;
  box-shadow: 0 4px 20px rgba(136, 118, 248, 0.3);
}

/* Loading Spinner */
.loading {
  display: none;
  text-align: center;
  padding: 50px;
}

.loading.show {
  display: block;
}

.spinner {
  border: 4px solid #29293a;
  border-top: 4px solid #8876f8;
  border-radius: 50%;
  width: 50px;
  height: 50px;
  animation: spin 1s linear infinite;
  margin: 0 auto 20px;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }

  100% {
    transform: rotate(360deg);
  }
}

/* Responsive Design */
@media (max-width: 768px) {
  .module-content {
    grid-template-columns: 1fr;
  }

  .form-row {
    grid-template-columns: 1fr;
  }

  .module-header h1 {
    font-size: 2rem;
  }

  .module-container {
    padding: 20px;
  }
}

/* Enhanced Footer Section */
.footer {
  background: linear-gradient(180deg, #0d0d0f 0%, #14141b 100%);
  color: #e6e6e6;
  padding: 60px 40px 30px;
  margin-top: 80px;
  border-top: 1px solid rgba(136, 118, 248, 0.2);
  position: relative;
}

.footer::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent 0%, #8876f8 50%, transparent 100%);
}

.footer-content {
  max-width: 1400px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.5fr 2fr;
  gap: 60px;
  margin-bottom: 40px;
}

.footer-brand {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.brand-header {
  display: flex;
  align-items: center;
  gap: 15px;
  margin-bottom: 10px;
}

.shield-icon-small {
  width: 40px;
  height: 40px;
  background: rgba(136, 118, 248, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.shield-icon-small:hover {
  background: rgba(136, 118, 248, 0.25);
  transform: scale(1.1);
}

.shield-icon-small svg {
  width: 22px;
  height: 22px;
  fill: #8876f8;
}

.brand-header h3 {
  font-size: 1.8rem;
  font-weight: 700;
  color: #fff;
  margin: 0;
  background: linear-gradient(135deg, #8876f8 0%, #c9baff 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.footer-brand p {
  color: #b7b3c9;
  line-height: 1.7;
  font-size: 1.05rem;
  margin: 0;
}

.footer-links-group {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40px;
}

.footer-col h4 {
  color: #8876f8;
  font-size: 1.2rem;
  font-weight: 600;
  margin-bottom: 20px;
  position: relative;
  padding-bottom: 10px;
}

.footer-col h4::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 30px;
  height: 2px;
  background: linear-gradient(90deg, #8876f8 0%, transparent 100%);
}

.footer-col ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.footer-col ul li {
  margin-bottom: 12px;
  transition: all 0.3s ease;
}

.footer-col ul li a {
  color: #b7b3c9;
  text-decoration: none;
  font-size: 1.05rem;
  transition: all 0.3s ease;
  display: inline-block;
  position: relative;
}

.footer-col ul li a::before {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  width: 0;
  height: 1px;
  background: #8876f8;
  transition: width 0.3s ease;
}

.footer-col ul li a:hover {
  color: #c9baff;
  transform: translateX(5px);
}

.footer-col ul li a:hover::before {
  width: 100%;
}

.footer-col ul li i {
  color: #8876f8;
  margin-right: 10px;
  font-size: 1.1rem;
}

.footer-bottom {
  max-width: 1400px;
  margin: 0 auto;
  padding-top: 30px;
  border-top: 1px solid rgba(136, 118, 248, 0.1);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 20px;
}

.footer-bottom p {
  color: #b7b3c9;
  font-size: 1rem;
  margin: 0;
}

.social-icons {
  display: flex;
  gap: 15px;
}

.social-icons a {
  width: 40px;
  height: 40px;
  background: rgba(136, 118, 248, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8876f8;
  font-size: 1.1rem;
  transition: all 0.3s ease;
  text-decoration: none;
}

.social-icons a:hover {
  background: linear-gradient(135deg, #8876f8 0%, #7059d2 100%);
  color: #fff;
  transform: translateY(-3px);
  box-shadow: 0 5px 15px rgba(136, 118, 248, 0.3);
}

/* Responsive Footer */
@media (max-width: 1024px) {
  .footer-content {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .footer-links-group {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 768px) {
  .footer {
    padding: 40px 20px 20px;
  }

  .footer-links-group {
    grid-template-columns: 1fr;
    gap: 30px;
  }

  .footer-bottom {
    flex-direction: column;
    text-align: center;
  }
}